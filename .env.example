# ============================================================================
# Domain & Environment Configuration
# ============================================================================

DOMAIN=whoscrizzz.com
CUSTOM_DOMAIN=whoscrizzz.com
ENVIRONMENT=production

# ============================================================================
# API Configuration
# ============================================================================

API_BASE_URL=https://api.whoscrizzz.com
API_VERSION=v1
API_TIMEOUT=30000

# ============================================================================
# GitHub OAuth Configuration
# Get these from: https://github.com/settings/developers
# ============================================================================

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=https://api.whoscrizzz.com/api/auth/github/callback

# ============================================================================
# Authentication (JWT)
# Generate a strong secret: openssl rand -base64 32
# ============================================================================

JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRES_IN=7d

# ============================================================================
# Email Configuration
# Choose provider: sendgrid, nodemailer, or cloudflare
# ============================================================================

EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@whoscrizzz.com

# Alternative: Nodemailer SMTP Configuration
# NODEMAILER_HOST=smtp.gmail.com
# NODEMAILER_PORT=587
# NODEMAILER_USER=your_email@gmail.com
# NODEMAILER_PASS=your_app_password

# ============================================================================
# Claude API Integration
# Get API key from: https://console.anthropic.com/
# ============================================================================

CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-opus-4-6

# ============================================================================
# Database Configuration
# Using Cloudflare D1 (SQLite) for the example
# ============================================================================

DATABASE_TYPE=d1
DATABASE_URL=cloudflare://whoscrizzz_db

# ============================================================================
# Cloudflare Configuration
# ============================================================================

CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# ============================================================================
# Development Configuration (when ENVIRONMENT=development)
# ============================================================================

# For local development with wrangler dev
DEV_API_BASE_URL=http://localhost:8787
DEV_DATABASE_URL=local_sqlite_database_url
